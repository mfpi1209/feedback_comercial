    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (!items.length) return [{ json: { conversa_bruta: '' } }];\n\nconst linhas = items.map(item => {\n  const j = item.json;\n  const role = (j.sender_type || 'bot').toLowerCase();\n  const name = (j.sender_name || '').trim();\n  const msg = j.message_text || '';\n  const hora = j.sent_at || '';\n  const tipo = (j.message_type || 'text').toLowerCase();\n\n  let papel;\n  if (role === 'contact') papel = `CLIENTE (${name})`;\n  else if (role === 'user') papel = `CONSULTOR (${name})`;\n  else papel = `BOT (${name})`;\n\n  if (!msg && ['voice','video','file','picture'].includes(tipo)) {\n    return `[${hora}] ${papel}: [${tipo.toUpperCase()} nao transcrito]`;\n  }\n  return `[${hora}] ${papel}: ${msg}`;\n});\n\nreturn [{ json: { conversa_bruta: linhas.join('\\n') } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 700],
      "id": "montar-01",
      "name": "Montar Transcricao"
    },
    {
      "parameters": {
        "jsCode": "let meta = {};\ntry { meta = $('Classificar Evento').first().json; } catch(e) {}\n\nconst conversa = $json.conversa_bruta || '';\n\nlet consultor = '';\nconst items = $('Buscar Msgs Supabase').all();\nfor (const it of items) {\n  if ((it.json.sender_type || '').toLowerCase() === 'user' && it.json.sender_name) {\n    consultor = it.json.sender_name;\n  }\n}\n\nreturn [{\n  json: {\n    consultor: consultor || '',\n    lead_nome: meta.lead_nome || '',\n    lead_telefone: meta.lead_telefone || '',\n    lead_id: meta.lead_id || null,\n    chat_id: (meta.chat_ids || [])[0] || '',\n    conversa: conversa,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 700],
