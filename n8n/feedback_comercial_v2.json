      "position": [-200, 400],
      "id": "wh-01",
      "name": "Webhook Comercial",
      "webhookId": "feedback_comercial"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst body = input.body || input;\nconst event = body.event || '';\n\nlet event_type = 'ignorar';\nif (event === 'atendimento_fechado') {\n  event_type = 'atendimento_fechado';\n} else if (event === 'new_message') {\n  event_type = 'new_message';\n}\n\nconst msgType = (body.message_type || 'text').toUpperCase();\nconst hasMedia = ['VOICE','VIDEO','FILE','PICTURE'].includes(msgType) && !!body.media_url;\n\n// Garante defaults para campos NOT NULL do Supabase\nconst senderType = body.sender_type || 'unknown';\nlet direction = body.direction;\nif (!direction) {\n  direction = senderType === 'contact' ? 'inbound' : 'outbound';\n}\n\nreturn [{\n  json: {\n    ...body,\n    direction: direction,\n    sender_type: senderType,\n    sender_name: body.sender_name || '',\n    chat_id: body.chat_id || '',\n    message_uid: body.message_uid || `auto-${Date.now()}`,\n    message_text: body.message_text || '',\n    message_type: body.message_type || 'text',\n    sent_at: body.sent_at || new Date().toISOString(),\n    _event_type: event_type,\n    _has_media: hasMedia,\n    _media_type: hasMedia ? msgType : null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [50, 400],
      "id": "class-01",
      "name": "Classificar Evento"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "r-new", "leftValue": "={{ $json._event_type }}", "rightValue": "new_message", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "new_message"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "r-atend", "leftValue": "={{ $json._event_type }}", "rightValue": "atendimento_fechado", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "atendimento"
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.3,
      "position": [300, 400],
