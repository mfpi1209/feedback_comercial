# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kommo_chat

# Kommo API (Bearer token)
KOMMO_BASE_URL=https://admamoeduitcombr.kommo.com
KOMMO_ACCESS_TOKEN=seu_access_token_aqui

# Kommo Amojo — Endpoint v1 (x-auth-token)
# amojo_id: obtido de GET /api/v4/account?with=amojo_id
KOMMO_AMOJO_ID=e29f43f0-ebca-413b-ab2f-8e806cec4998
# Token e refresh_token: obtidos do Local Storage do Kommo (chave: amojo_token)
KOMMO_AMOJO_TOKEN=seu_x_auth_token_aqui
KOMMO_AMOJO_REFRESH_TOKEN=seu_refresh_token_aqui

# Webhook secret (para validar webhooks recebidos do Kommo)
KOMMO_WEBHOOK_SECRET=

# IA — processamento de mídia e análise
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=AIza...

# Supabase — gravação de feedback comercial
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...

# Sync
SYNC_BATCH_SIZE=50
SYNC_INTERVAL_SECONDS=300
