# ============================================================
#  Kommo Chat Dispatcher — Variáveis de Ambiente
# ============================================================
#  Copie este arquivo para .env e preencha os valores.
#  NÃO commit o .env real — ele contém segredos.
# ============================================================

# Banco local (SQLite) — em Docker o compose sobrescreve para /app/data/
DATABASE_URL=sqlite+aiosqlite:///./kommo_chat.db

# Kommo API (Bearer token p/ REST API)
KOMMO_BASE_URL=https://SUA_CONTA.kommo.com
KOMMO_ACCESS_TOKEN=

# Kommo Amojo (chat — token p/ API de mensagens)
KOMMO_AMOJO_ID=
KOMMO_AMOJO_TOKEN=
KOMMO_AMOJO_REFRESH_TOKEN=

# Login Kommo — renovação automática do amojo token via Playwright
KOMMO_LOGIN_EMAIL=
KOMMO_LOGIN_PASSWORD=
TOKEN_RENEWAL_INTERVAL_HOURS=20

# IA — chaves usadas pelo n8n (não pelo Python diretamente)
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Supabase — tabelas mensagens_atendimento_comercial e feedback_comercial
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_KEY=

# n8n — webhook que recebe new_message e atendimento_fechado
N8N_WEBHOOK_URL=https://SEU_N8N/webhook/feedback_comercial

# Sync
SYNC_BATCH_SIZE=50
SYNC_INTERVAL_SECONDS=300
